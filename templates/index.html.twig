<!DOCTYPE html>
<html class="h-100">
    <head>
        <meta charset="UTF-8"/>
        <title>{% block title %}ProxyParts{% endblock %}</title>
        {% block stylesheets %}
            <link href="/vendor/css/bootstrap/bootstrap.min.css" rel="stylesheet">
        {% endblock %}
    </head>
    <body class="d-flex flex-column h-100">
        <nav class="bg-light border-bottom">
            <div class="container d-flex flex-wrap">
                <ul class="nav me-auto">
                    <li class="nav-item"><a href="#" class="nav-link link-dark active px-2">О проекте</a></li>
                    <li class="nav-item"><a href="#" class="nav-link link-dark px-2">Новости</a></li>
                    <li class="nav-item"><a href="#" class="nav-link link-dark px-2">Описание API</a></li>
                    <li class="nav-item"><a href="#" class="nav-link link-dark px-2">Контакты</a></li>
                </ul>
                <ul class="nav py-1">
                    <li class="nav-item"><a href="/login" class="btn btn-sm btn-outline-secondary rounded-pill">Войти</a></li>
                    <li class="nav-item ms-4"><a href="/register" class="btn btn-sm btn-outline-secondary rounded-pill">Регистрация</a></li>
                </ul>
            </div>
        </nav>
    <header class="py-1 mb-4 border-bottom">
        <div class="container d-flex flex-wrap justify-content-center">
           <div class="pt-1 text-center"> Поиск запчасти</div>
           <div class="mx-3">
            
            <form method="post" action="/search">
                <input type="search" class="form-control form-control-sm" placeholder="Номер..." aria-label="Search">
           </div>
           <div>
               <button class="btn btn-sm btn-outline-primary">Найти</button>
           </div>
           </form>
      </div>
    </header>      
    <main class="flex-shrink-0">
        <div class="container">    
            {% block body %}

            {% endblock %}
        </div>
    </main>
    
    
    <footer class="footer mt-auto py-3 bg-light">
        <div class="container text-center">
            <span class="text-muted">ProxyParts 2023</span>
        </div>
    </footer>
    
    
    {% block javascripts %}
         

    {% endblock %}
        
    </body>    
</html>
